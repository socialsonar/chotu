{
  "name": "@socialsonar/chotu",
  "version": "0.3.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/socialsonar/chotu.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.cjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "bun run --cwd test start",
    "test:dev": "bun run --cwd test dev",
    "test:unit": "bun test --cwd test --serial src/timeout-lease.test.ts src/multi-instance.test.ts src/step-timeout.test.ts src/hooks.test.ts src/workflow-hooks.test.ts src/abort-workflow.test.ts src/purge-terminal.test.ts src/durability.test.ts src/hooks-stress.test.ts",
    "test:stress": "bun run --cwd test stress",
    "test:stress:quick": "bun run --cwd test stress:quick",
    "build": "npm run build:js && npm run build:types",
    "build:js": "esbuild ./src/index.ts --bundle --outfile=./dist/index.cjs --platform=node --format=cjs --packages=external",
    "build:types": "tsc --emitDeclarationOnly",
    "build:watch:js": "esbuild ./src/index.ts --bundle --outfile=./dist/index.cjs --platform=node --format=cjs --packages=external --watch",
    "build:watch:types": "tsc --emitDeclarationOnly --watch --preserveWatchOutput",
    "build:watch": "npm run build:watch:js & npm run build:watch:types; wait",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ioredis": "^5.6.1",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
